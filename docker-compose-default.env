# Media directory on the host
MEDIA_PATH=/media/video
# Host username. Run `id` to check the target host user.
USERNAME=atm
# Host group name. Run `id` to check the target host group.
GROUPNAME=atm
# Numeric user ID used by linuxserver.io containers.
PUID=1000
# Numeric group ID used by linuxserver.io containers.
PGID=1000
# Configuration directory
CONFIG_PATH=./config
# Timezone
TZ=Asia/Singapore
